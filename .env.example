# VeriAlign configuration

# Leave these empty for local demo mode.
# Set both values to forward requests to a real OpenAI-compatible provider.
VERIALIGN_UPSTREAM_BASE_URL=
VERIALIGN_UPSTREAM_API_KEY=

# Optional: Anthropic provider configuration
VERIALIGN_ANTHROPIC_BASE_URL=https://api.anthropic.com
VERIALIGN_ANTHROPIC_API_KEY=

# Optional: Local Ollama/OpenAI-compatible provider
VERIALIGN_LOCAL_BASE_URL=http://localhost:11434
VERIALIGN_LOCAL_API_KEY=

# Request timeout for the upstream provider, in seconds.
VERIALIGN_UPSTREAM_TIMEOUT_SECONDS=60

# SQLite database path for request/response traces.
VERIALIGN_DB_PATH=./verialign.sqlite3

# Proxy authentication (optional but recommended for production)
# Set VERIALIGN_REQUIRE_PROXY_AUTH=true and provide a key to enable
VERIALIGN_PROXY_API_KEY=
VERIALIGN_REQUIRE_PROXY_AUTH=false

# Rate limiting (requests per minute / tokens per minute)
VERIALIGN_RATE_LIMIT_RPM=60
VERIALIGN_RATE_LIMIT_TPM=100000

# Redact sensitive data from stored traces
VERIALIGN_REDACT_TRACES=true

# Maximum request body size in bytes (default 10MB)
VERIALIGN_MAX_REQUEST_BODY_SIZE=10485760

# CORS allowed origins (comma-separated, default allows all)
# Set to specific origins in production, e.g. https://dashboard.example.com
VERIALIGN_CORS_ALLOWED_ORIGINS=*

# Proxy request timeout (seconds)
VERIALIGN_PROXY_TIMEOUT_SECONDS=120

# Database URL (async engines: postgresql+asyncpg://...)
# Leave empty to use SQLite via VERIALIGN_DB_PATH
VERIALIGN_DATABASE_URL=

# Web search grounding (optional — for verifying claims against live web sources)
# Supported providers: tavily (free tier), google/serpapi
VERIALIGN_WEB_SEARCH_API_KEY=
VERIALIGN_WEB_SEARCH_PROVIDER=tavily

# Valkey/Redis cache (optional — replaces in-memory cache when set)
# Example: valkey://localhost:6379/0
VERIALIGN_VALKEY_URL=

# Sentry error tracking (optional)
VERIALIGN_SENTRY_DSN=

# OpenTelemetry (optional — enable distributed tracing)
VERIALIGN_ENABLE_OTEL=false

# Admin API key (optional — protects /admin/* endpoints)
VERIALIGN_ADMIN_API_KEY=

# Safety guardrails (enabled by default)
VERIALIGN_SAFETY_JAILBREAK_ENABLED=true
VERIALIGN_SAFETY_TOXICITY_ENABLED=true
VERIALIGN_SAFETY_PII_REDACT_ENABLED=true